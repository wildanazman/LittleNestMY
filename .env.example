VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-side only. Do not expose this in browser code or Vite env vars.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-functions-later

# Stripe (server-side only — used by /api/stripe-* endpoints)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe price ID for Premium one-time purchase (RM 39.90, set in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_ID=price_your_premium_price_id
